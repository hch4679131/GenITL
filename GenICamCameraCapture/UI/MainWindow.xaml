<Window x:Class="GenICamCameraCapture.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GenICam 相机采集系统" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen" Closing="Window_Closing">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧控制面板 -->
        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0" Background="#F8F8F8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">

                    <!-- 厂商选择 -->
                    <TextBlock Text="相机厂商" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbProvider" SelectedIndex="0" Margin="0,0,0,4">
                        <ComboBoxItem Content="华睿 (HuaRay)" Tag="huaray"/>
                        <ComboBoxItem Content="海康 (Hikvision)" Tag="hikvision"/>
                    </ComboBox>

                    <!-- CTI 配置 -->
                    <TextBlock Text="CTI 文件路径" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtCtiPath" Text="d:\tool\MV Viewer\Runtime\x64\MVProducerGEV.cti"
                             TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <Button x:Name="btnBrowseCti" Content="浏览..." Click="BtnBrowseCti_Click"
                            HorizontalAlignment="Left"/>

                    <Separator Margin="0,10"/>

                    <!-- 初始化与枚举 -->
                    <TextBlock Text="设备管理" FontWeight="Bold" Margin="0,0,0,4"/>
                    <Button x:Name="btnInitialize" Content="初始化 CTI" Click="BtnInitialize_Click"/>
                    <Button x:Name="btnEnumerate" Content="枚举设备" Click="BtnEnumerate_Click" IsEnabled="False"/>

                    <TextBlock Text="发现的设备:" Margin="0,8,0,4"/>
                    <ListBox x:Name="lstDevices" Height="120" DisplayMemberPath="DisplayText"/>

                    <Button x:Name="btnConnect" Content="连接设备" Click="BtnConnect_Click" IsEnabled="False"/>
                    <Button x:Name="btnDisconnect" Content="断开设备" Click="BtnDisconnect_Click" IsEnabled="False"/>

                    <Separator Margin="0,10"/>

                    <!-- 采集控制 -->
                    <TextBlock Text="采集控制" FontWeight="Bold" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnStartGrab" Content="开始采集" Click="BtnStartGrab_Click"
                                IsEnabled="False" Background="#4CAF50" Foreground="White"/>
                        <Button x:Name="btnStopGrab" Content="停止采集" Click="BtnStopGrab_Click"
                                IsEnabled="False" Background="#F44336" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="缓冲区数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="txtBufferCount" Text="16" Width="50" VerticalAlignment="Center"/>
                    </StackPanel>

                    <CheckBox x:Name="chkAutoSave" Content="自动保存帧 (每10帧)" Margin="0,8,0,0"/>

                    <Separator Margin="0,10"/>

                    <!-- 参数控制 -->
                    <TextBlock Text="参数控制" FontWeight="Bold" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="曝光(μs):" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="txtExposureTime" Text="1000" Width="70" VerticalAlignment="Center"/>
                        <Button x:Name="btnSetExposure" Content="设置" Click="BtnSetExposure_Click"
                                Margin="4,0,0,0" Padding="8,2" IsEnabled="False"/>
                        <Button x:Name="btnGetExposure" Content="读取" Click="BtnGetExposure_Click"
                                Margin="4,0,0,0" Padding="8,2" IsEnabled="False"/>
                    </StackPanel>

                    <Separator Margin="0,10"/>

                    <!-- 状态信息 -->
                    <TextBlock Text="状态信息" FontWeight="Bold" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="状态: " Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtStatus" Text="未连接"
                                   Foreground="Gray" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="帧数: " Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtFrameCount" Text="0" Margin="0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="分辨率: " Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtResolution" Text="-" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="帧率: " Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtFps" Text="-" Margin="0,2"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="像素格式: " Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtPixelFormat" Text="-" Margin="0,2"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧主区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- 图像显示区 -->
            <Border Grid.Row="0" Background="Black" Margin="4">
                <Grid>
                    <TextBlock x:Name="txtImagePlaceholder" Text="等待图像..."
                               Foreground="#666" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Image x:Name="imgDisplay" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Grid>
            </Border>

            <!-- 日志区 -->
            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F0F0F0">
                        <TextBlock Text="日志" FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                        <Button x:Name="btnClearLog" Content="清空" Click="BtnClearLog_Click"
                                Padding="8,2" Margin="4" MinWidth="50"/>
                    </StackPanel>
                    <TextBox Grid.Row="1" x:Name="txtLog" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                             Background="#1E1E1E" Foreground="#CCCCCC" BorderThickness="0"
                             Padding="4"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
